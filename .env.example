# ============================================================
# Configuration de la source de données — Risk Dashboard
# ============================================================
#
# 1. Copiez ce fichier en ".env" à la racine du projet
#    (le fichier .env est ignoré par git)
#
# 2. Renseignez vos paramètres de connexion
#
# 3. Redémarrez l'application Streamlit
# ============================================================


# ----------------------------------------------------------
# Source de données
# ----------------------------------------------------------
# false (défaut) → lecture des fichiers CSV dans data/cleaned/
# true           → connexion à la base de données (DATABASE_URL requis)
USE_DATABASE=false


# ----------------------------------------------------------
# URL de connexion SQLAlchemy (requis si USE_DATABASE=true)
# ----------------------------------------------------------
# Décommentez et adaptez selon votre SGBD :

# PostgreSQL
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/risk_db

# MySQL / MariaDB
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/risk_db

# Microsoft SQL Server (ODBC)
# DATABASE_URL=mssql+pyodbc://user:password@serveur/risk_db?driver=ODBC+Driver+17+for+SQL+Server

# Microsoft SQL Server (authentification Windows)
# DATABASE_URL=mssql+pyodbc://@serveur/risk_db?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Oracle
# DATABASE_URL=oracle+cx_oracle://user:password@host:1521/service_name

# SQLite (local, pour tests)
# DATABASE_URL=sqlite:///./data/risk.db


# ----------------------------------------------------------
# Schéma SQL (optionnel)
# ----------------------------------------------------------
# Schéma contenant les tables (défaut: "public" pour PostgreSQL)
# DB_SCHEMA=public
